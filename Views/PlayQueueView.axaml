<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Jukebox.ViewModels"
             xmlns:models="using:Jukebox.Models"
             mc:Ignorable="d"
             d:DesignWidth="260"
             d:DesignHeight="620"
             x:Class="Jukebox.Views.PlayQueueView"
             x:DataType="vm:JukeboxViewModel">

    <UserControl.KeyBindings>
        <KeyBinding Gesture="Delete"
                    Command="{Binding PlaylistViewModel.RemovePlayQueueSelectedCommand}"
                    CommandParameter="{Binding #PlayQueueDataGrid.SelectedItems}"/>
        <KeyBinding Gesture="Ctrl+Shift+L"
                    Command="{Binding PlaylistViewModel.ClearPlayQueueCommand}"/>
        <KeyBinding Gesture="Ctrl+S"
                    Command="{Binding PlaylistViewModel.SavePlayQueueAsPlaylistCommand}"/>
        <KeyBinding Gesture="Enter"
                    Command="{Binding PlayTrackCommand}"
                    CommandParameter="{Binding #PlayQueueDataGrid.SelectedItem}"/>
    </UserControl.KeyBindings>

    <Design.DataContext>
        <vm:JukeboxViewModel/>
    </Design.DataContext>

    <UserControl.Styles>
        <Style Selector="DataGrid.media-grid DataGridRow">
            <Setter Property="Height" Value="NaN"/>
        </Style>
    </UserControl.Styles>

    <Grid Margin="10,2,10,4" RowDefinitions="Auto,Auto,*,Auto">
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="2,2,2,4">
            <StackPanel Spacing="2">
                <TextBlock Classes="media-eyebrow" Text="UP NEXT"/>
                <TextBlock Classes="media-page-title" Text="Play Queue"/>
            </StackPanel>
            <TextBlock Grid.Column="1"
                       Classes="media-muted"
                       Text="{Binding PlaylistViewModel.PlayQueue.Count, StringFormat='{}{0} tracks'}"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"/>
        </Grid>

        <Grid Grid.Row="1"
              ColumnDefinitions="*,Auto,Auto"
              ColumnSpacing="6"
              Margin="0,0,0,10">
            <Button Grid.Column="0"
                    Classes="media-primarybutton"
                    HorizontalAlignment="Left"
                    ToolTip.Tip="Save Queue As Playlist (Ctrl+S)"
                    Command="{Binding PlaylistViewModel.SavePlayQueueAsPlaylistCommand}">
                <StackPanel Orientation="Horizontal" Spacing="7">
                    <PathIcon Data="{StaticResource MediaIconSave}"
                              Width="16" Height="16"
                              Foreground="White"/>
                    <TextBlock Text="Save queue" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Button Grid.Column="1"
                    Classes="media-iconbutton"
                    ToolTip.Tip="Remove Selected (Delete)"
                    Command="{Binding PlaylistViewModel.RemovePlayQueueSelectedCommand}"
                    CommandParameter="{Binding #PlayQueueDataGrid.SelectedItems}">
                <PathIcon Classes="media-vector"
                          Data="{StaticResource MediaIconRemove}"/>
            </Button>
            <Button Grid.Column="2"
                    Classes="media-iconbutton danger"
                    ToolTip.Tip="Clear Play Queue (Ctrl+Shift+L)"
                    Command="{Binding PlaylistViewModel.ClearPlayQueueCommand}">
                <PathIcon Classes="media-vector danger"
                          Data="{StaticResource MediaIconDelete}"/>
            </Button>
        </Grid>

        <Border Grid.Row="2" Classes="media-card">
        <DataGrid x:Name="PlayQueueDataGrid"
                  Classes="media-grid"
                  ItemsSource="{Binding PlaylistViewModel.PlayQueueView}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Extended"
                  HeadersVisibility="Column"
                  CanUserReorderColumns="False"
                  CanUserResizeColumns="True"
                  CanUserSortColumns="False"
                  GridLinesVisibility="Horizontal"
                  DoubleTapped="PlayQueueDataGrid_DoubleTapped">
            <DataGrid.ContextMenu>
                <ContextMenu x:Name="PlayQueueContextMenu"
                             Opened="PlayQueueContextMenu_Opened">
                    <MenuItem x:Name="PlayQueuePlayNowMenuItem"
                              Header="Play now"
                              Click="PlayQueuePlayNow_Click"/>
                    <Separator/>
                    <MenuItem x:Name="PlayQueueRemoveMenuItem"
                              Header="Remove from queue"
                              InputGesture="Delete"
                              Click="PlayQueueRemove_Click"/>
                    <MenuItem Header="Save queue as playlist"
                              InputGesture="Ctrl+S"
                              Click="PlayQueueSave_Click"/>
                    <MenuItem Header="Clear queue"
                              InputGesture="Ctrl+Shift+L"
                              Click="PlayQueueClear_Click"/>
                </ContextMenu>
            </DataGrid.ContextMenu>
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="Title"
                                        x:DataType="models:JukeboxTrack"
                                        Width="7*"
                                        CellTemplate="{StaticResource TrackTitleCellTemplate}"/>
            </DataGrid.Columns>
        </DataGrid>
        </Border>

        <Border Grid.Row="3"
                Classes="media-card"
                Margin="0,8,0,0"
                Padding="10,7">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0"
                           Text="{Binding PlaylistViewModel.PlayQueueSummary}"
                           Foreground="{DynamicResource MediaPanelMutedBrush}"
                           FontSize="11"
                           VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="4"
                            Margin="8,0,0,0">
                    <Button Classes="media-iconbutton"
                            Width="30" Height="30"
                            ToolTip.Tip="Move selected track(s) up"
                            Click="MovePlayQueueSelectedUp_Click">
                        <Image Source="avares://Jukebox/Assets/Icons/uparrow.png"
                               Width="17" Height="17"
                               Stretch="Uniform"/>
                    </Button>
                    <Button Classes="media-iconbutton"
                            Width="30" Height="30"
                            ToolTip.Tip="Move selected track(s) down"
                            Click="MovePlayQueueSelectedDown_Click">
                        <Image Source="avares://Jukebox/Assets/Icons/downarrow.png"
                               Width="17" Height="17"
                               Stretch="Uniform"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
