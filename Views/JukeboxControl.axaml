<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Jukebox.ViewModels"
             xmlns:localViews="using:Jukebox.Views"
             xmlns:vis="using:JukeboxVisualizations.Controls"
             xmlns:vlc="clr-namespace:LibVLCSharp.Avalonia;assembly=LibVLCSharp.Avalonia"
             mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="720"
             x:Class="Jukebox.Views.JukeboxControl"
             x:DataType="vm:JukeboxViewModel"
             Background="Transparent">

    <Design.DataContext>
        <vm:JukeboxViewModel/>
    </Design.DataContext>

    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        
        <!-- Main Area with Sliding Side Panel -->
        <SplitView Grid.Row="0"
                   DisplayMode="Inline"
                   OpenPaneLength="400"
                   PanePlacement="Left">
            
            <SplitView.IsPaneOpen>
                <MultiBinding Converter="{x:Static BoolConverters.Or}">
                    <Binding Path="IsPlaylistVisible" />
                    <Binding Path="IsPickerVisible" />
                </MultiBinding>
            </SplitView.IsPaneOpen>

            <SplitView.Pane>
                <Border Background="#1A1A1A" BorderBrush="{DynamicResource PanelBorder}" BorderThickness="0,0,1,0">
                    <Grid>
                        <Grid IsVisible="{Binding IsPlaylistVisible}" Margin="5">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Spacing="5" Margin="0,5,0,10">
                                <StackPanel Orientation="Horizontal" Spacing="5" HorizontalAlignment="Center">
                                    <Button Classes="transparentbutton" Background="Transparent" Width="30" Height="30" ToolTip.Tip="Add Files" Click="AddFiles_Click">
                                        <TextBlock Text="➕" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="16"/>
                                    </Button>
                                    <Button Classes="transparentbutton" Background="Transparent" Width="30" Height="30" ToolTip.Tip="Add Folder" Click="AddFolder_Click">
                                        <Image Source="avares://Jukebox/Assets/Buttons/folder.png" Width="20" Height="20"/>
                                    </Button>
                                    <Button Classes="transparentbutton" Background="Transparent" Width="30" Height="30" ToolTip.Tip="Remove Selected" Command="{Binding PlaylistViewModel.RemoveSelectedCommand}" CommandParameter="{Binding #PlaylistDataGrid.SelectedItems}">
                                        <Image Source="avares://Jukebox/Assets/Buttons/remove.png" Width="20" Height="20"/>
                                    </Button>
                                    <Button Classes="transparentbutton" Background="Transparent" Width="30" Height="30" ToolTip.Tip="Clear Playlist" Command="{Binding PlaylistViewModel.ClearPlaylistCommand}">
                                        <Image Source="avares://Jukebox/Assets/Buttons/x.png" Width="16" Height="16"/>
                                    </Button>
                                </StackPanel>
                                
                                <TextBox PlaceholderText="Search Playlist..." Margin="5,5,5,0"/>
                            </StackPanel>

                            <DataGrid x:Name="PlaylistDataGrid" Grid.Row="1" 
                                      ItemsSource="{Binding PlaylistViewModel.Playlist}" 
                                      AutoGenerateColumns="False" 
                                      IsReadOnly="True" 
                                      SelectionMode="Extended"
                                      HeadersVisibility="Column"
                                      CanUserReorderColumns="False"
                                      CanUserResizeColumns="True"
                                      CanUserSortColumns="True"
                                      GridLinesVisibility="Horizontal"
                                      DoubleTapped="PlaylistDataGrid_DoubleTapped">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Title" Binding="{Binding DisplayName}" Width="5*" />
                                    <DataGridTextColumn Header="Length" Binding="{Binding Length}" Width="2*" />
                                    <DataGridTextColumn Header="Bitrate" Binding="{Binding Bitrate}" Width="2*" />
                                </DataGrid.Columns>
                            </DataGrid>

                            <TextBlock Grid.Row="2" Text="{Binding PlaylistViewModel.PlaylistSummary}" Foreground="{DynamicResource SubtleTextBrush}" 
                                       FontSize="11" HorizontalAlignment="Center" Margin="0,5,0,5"/>
                        </Grid>
                        <Grid IsVisible="{Binding IsPickerVisible}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            
                            <StackPanel Grid.Row="0" Margin="10,0,10,10" Spacing="5">
                                <TextBlock Text="🎇 Visualizations" Foreground="White" FontSize="20" FontWeight="Bold"/>
                                <TextBlock Text="Double click to apply selected visualization" Foreground="{DynamicResource SubtleTextBrush}" FontSize="12"/>
                                
                                <Border Background="#22FFFFFF" CornerRadius="4" Padding="10" Margin="0,5,0,0">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <ToggleSwitch IsChecked="{Binding VisualizerViewModel.IsVisualizerRandomizerEnabled}" OnContent="Random" OffContent="Random" FontSize="12" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <StackPanel Orientation="Horizontal" Spacing="10" IsEnabled="{Binding VisualizerViewModel.IsVisualizerRandomizerEnabled}">
                                            <TextBlock Text="Speed:" VerticalAlignment="Center" Foreground="#AAAAAA" FontSize="12"/>
                                            <Slider Minimum="10" Maximum="60" Value="{Binding VisualizerViewModel.VisualizerRandomizerIntervalSeconds}" Width="80" VerticalAlignment="Center" TickPlacement="BottomRight" TickFrequency="10"/>
                                            <TextBlock Text="{Binding VisualizerViewModel.VisualizerRandomizerIntervalSeconds, StringFormat=\{0\}s}" VerticalAlignment="Center" Foreground="White" FontSize="12" Width="30"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                            
                            <TreeDataGrid x:Name="VisualizerTreeDataGrid" Grid.Row="1" Source="{Binding VisualizerViewModel.VisualizerSource}" FontSize="12" DoubleTapped="VisualizerTreeDataGrid_DoubleTapped">
                                <TreeDataGrid.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Add to Favorites" Command="{Binding VisualizerViewModel.AddToFavoritesCommand}" CommandParameter="{Binding #VisualizerTreeDataGrid.RowSelection.SelectedItems[0]}" />
                                        <MenuItem Header="Rename" Command="{Binding VisualizerViewModel.RenameVisualizerCommand}" CommandParameter="{Binding #VisualizerTreeDataGrid.RowSelection.SelectedItems[0]}" />
                                        <MenuItem Header="Remove from Favorites" Command="{Binding VisualizerViewModel.RemoveFromFavoritesCommand}" CommandParameter="{Binding #VisualizerTreeDataGrid.RowSelection.SelectedItems[0]}" />
                                    </ContextMenu>
                                </TreeDataGrid.ContextMenu>
                            </TreeDataGrid>
                        </Grid>
                    </Grid>
                </Border>
            </SplitView.Pane>

            <SplitView.Content>
                <Border Background="#222222" Margin="10" CornerRadius="8" ClipToBounds="True">
                    <Grid>
                        <TextBlock Text="No Visualizer Selected" Foreground="#888888" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="24"
                                   IsVisible="{Binding VisualizerViewModel.SelectedVisualizerPath, Converter={x:Static StringConverters.IsNullOrEmpty}}" />
                        <vlc:VideoView MediaPlayer="{Binding MediaPlayer}" IsVisible="{Binding !IsVisualizerVisible}" />
                        <vis:ProjectMControl x:Name="ProjectMDisplay" IsVisible="{Binding IsVisualizerVisible}" />

                        <!-- EQ Slide-up Panel -->
                        <Border Background="#B3000000" VerticalAlignment="Bottom" 
                                CornerRadius="8,8,0,0" Padding="20"
                                IsVisible="{Binding IsEqVisible}">
                            <Grid RowDefinitions="Auto,*">
                                <Grid Grid.Row="0" Margin="0,0,0,20">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10">
                                        <TextBlock Text="Preset:" Foreground="#AAAAAA" VerticalAlignment="Center"/>
                                        <ComboBox ItemsSource="{Binding EqViewModel.EqPresets}" SelectedItem="{Binding EqViewModel.SelectedEqPreset}" Width="112"/>
                                    </StackPanel>
                                </Grid>
                                <Viewbox Grid.Row="1" Stretch="Uniform" StretchDirection="DownOnly">
                                    <ItemsControl ItemsSource="{Binding EqViewModel.EqBands}" HorizontalAlignment="Center">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" Spacing="25"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Vertical" Spacing="10" HorizontalAlignment="Center">
                                                    <TextBlock Text="{Binding Gain, StringFormat=\{0:F1\}}" FontSize="11" Foreground="White" HorizontalAlignment="Center"/>
                                                    <Slider Minimum="-15" Maximum="15" Value="{Binding Gain}" Orientation="Vertical" Height="150" HorizontalAlignment="Center"/>
                                                    <TextBlock Text="{Binding FrequencyLabel}" FontSize="12" Foreground="#AAAAAA" HorizontalAlignment="Center" FontWeight="Bold"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Viewbox>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </SplitView.Content>
        </SplitView>
        
        <!-- Bottom Control Bar -->
        <localViews:TransportBarView Grid.Row="1" />
    </Grid>
</UserControl>
