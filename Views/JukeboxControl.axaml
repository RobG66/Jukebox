<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Jukebox.ViewModels"
             xmlns:localViews="using:Jukebox.Views"
             xmlns:vlc="clr-namespace:LibVLCSharp.Avalonia;assembly=LibVLCSharp.Avalonia"
             mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="720"
             x:Class="Jukebox.Views.JukeboxControl"
             x:DataType="vm:JukeboxViewModel"
             Background="Transparent">

    <Design.DataContext>
        <vm:JukeboxViewModel/>
    </Design.DataContext>

    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        
        <!-- Main Area with Sliding Side Panel -->
        <SplitView Grid.Row="0"
                   DisplayMode="Inline"
                   OpenPaneLength="400"
                   PanePlacement="Left">
            
            <SplitView.IsPaneOpen>
                <MultiBinding Converter="{x:Static BoolConverters.Or}">
                    <Binding Path="IsPlaylistVisible" />
                    <Binding Path="IsPickerVisible" />
                </MultiBinding>
            </SplitView.IsPaneOpen>

            <SplitView.Pane>
                <Border Background="#1A1A1A" BorderBrush="{DynamicResource PanelBorder}" BorderThickness="0,0,1,0">
                    <Grid>
                        <Grid IsVisible="{Binding IsPlaylistVisible}" Margin="5">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Spacing="5" Margin="0,5,0,10">
                                <StackPanel Orientation="Horizontal" Spacing="5" HorizontalAlignment="Center">
                                    <Button Classes="transparentbutton" Background="Transparent" Width="30" Height="30" ToolTip.Tip="Add Files" Click="AddFiles_Click">
                                        <TextBlock Text="➕" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="16"/>
                                    </Button>
                                    <Button Classes="transparentbutton" Background="Transparent" Width="30" Height="30" ToolTip.Tip="Add Folder" Click="AddFolder_Click">
                                        <Image Source="avares://Jukebox/Assets/Buttons/folder.png" Width="20" Height="20"/>
                                    </Button>
                                    <Button Classes="transparentbutton" Background="Transparent" Width="30" Height="30" ToolTip.Tip="Remove Selected" Command="{Binding RemoveSelectedCommand}" CommandParameter="{Binding #PlaylistDataGrid.SelectedItems}">
                                        <Image Source="avares://Jukebox/Assets/Buttons/remove.png" Width="20" Height="20"/>
                                    </Button>
                                    <Button Classes="transparentbutton" Background="Transparent" Width="30" Height="30" ToolTip.Tip="Clear Playlist" Command="{Binding ClearPlaylistCommand}">
                                        <Image Source="avares://Jukebox/Assets/Buttons/x.png" Width="16" Height="16"/>
                                    </Button>
                                </StackPanel>
                                
                                <TextBox PlaceholderText="Search Playlist..." Margin="5,5,5,0"/>
                            </StackPanel>

                            <DataGrid x:Name="PlaylistDataGrid" Grid.Row="1" 
                                      ItemsSource="{Binding Playlist}" 
                                      AutoGenerateColumns="False" 
                                      IsReadOnly="True" 
                                      SelectionMode="Extended"
                                      HeadersVisibility="Column"
                                      CanUserReorderColumns="False"
                                      CanUserResizeColumns="True"
                                      CanUserSortColumns="True"
                                      GridLinesVisibility="Horizontal"
                                      DoubleTapped="PlaylistDataGrid_DoubleTapped">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Title" Binding="{Binding DisplayName}" Width="5*" />
                                    <DataGridTextColumn Header="Length" Binding="{Binding Length}" Width="2*" />
                                    <DataGridTextColumn Header="Bitrate" Binding="{Binding Bitrate}" Width="2*" />
                                </DataGrid.Columns>
                            </DataGrid>

                            <TextBlock Grid.Row="2" Text="6 Tracks | 0h 23m total" Foreground="{DynamicResource SubtleTextBrush}" 
                                       FontSize="11" HorizontalAlignment="Center" Margin="0,5,0,5"/>
                        </Grid>
                        <Grid IsVisible="{Binding IsPickerVisible}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            
                            <StackPanel Grid.Row="0" Margin="10,0,10,10">
                                <TextBlock Text="🎇 Visualizations" Foreground="White" FontSize="20" FontWeight="Bold"/>
                                <TextBlock Text="Select a ProjectM preset" Foreground="{DynamicResource SubtleTextBrush}" FontSize="12"/>
                            </StackPanel>
                            
                            <TreeDataGrid Grid.Row="1" Source="{Binding VisualizerSource}" FontSize="12" />
                        </Grid>
                    </Grid>
                </Border>
            </SplitView.Pane>

            <SplitView.Content>
                <Border Background="#222222" Margin="10" CornerRadius="8">
                    <TextBlock Text="Main Visualizer / Video Area" Foreground="#888888" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="24"/>
                </Border>
            </SplitView.Content>
        </SplitView>
        
        <!-- Bottom Control Bar -->
        <localViews:TransportBarView Grid.Row="1" />
    </Grid>
</UserControl>
