<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Jukebox.ViewModels"
             xmlns:vis="using:JukeboxVisualizations.Controls"
             xmlns:vlc="clr-namespace:LibVLCSharp.Avalonia;assembly=LibVLCSharp.Avalonia"
             mc:Ignorable="d" d:DesignWidth="880" d:DesignHeight="655"
             x:Class="Jukebox.Views.ContentView"
             x:DataType="vm:JukeboxViewModel">

    <Design.DataContext>
        <vm:JukeboxViewModel/>
    </Design.DataContext>

    <Border Background="{DynamicResource ContentBackground}" ClipToBounds="True">
        <Grid x:Name="ContentGrid">

            <!-- Initializing state -->
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="20" IsVisible="{Binding IsInitializing}">
                <TextBlock Text="Initializing..."
                           Foreground="#888888"
                           HorizontalAlignment="Center"
                           FontSize="24"/>
                <ProgressBar IsIndeterminate="True" 
                             Width="200" 
                             Height="4" 
                             HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Video playback host -->
            <Decorator x:Name="VideoHost"
                       IsVisible="{Binding !IsVisualizerVisible}"/>

            <!-- ProjectM visualizer host -->
            <Decorator x:Name="ProjectMHost"
                       IsVisible="{Binding IsVisualizerVisible}"/>

            <Border x:Name="OsdAnchor" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="20,20,0,0" Width="1" Height="1" Background="Transparent" IsHitTestVisible="False"/>

            <!-- OSD Current Title -->
            <Popup IsOpen="{Binding IsShowPlayingVisible}"
                   PlacementTarget="{Binding #OsdAnchor}"
                   Placement="Right"
                   IsHitTestVisible="False"
                   WindowManagerAddShadowHint="False">
                <TextBlock Text="{Binding ShowPlayingText}"
                           Opacity="{Binding ShowPlayingOpacity}"
                           Foreground="White"
                           FontSize="24"
                           FontWeight="SemiBold"
                           MaxWidth="{Binding #ContentGrid.Bounds.Width}"
                           TextTrimming="CharacterEllipsis" />
            </Popup>

            <!-- EQ slide-up overlay -->
            <Border Background="{DynamicResource EqOverlayBackground}"
                    VerticalAlignment="Bottom"
                    CornerRadius="8,8,0,0"
                    Padding="20"
                    IsVisible="{Binding IsEqVisible}">
                <Grid RowDefinitions="Auto,*">

                    <!-- Preset selector -->
                    <Grid Grid.Row="0" Margin="0,0,0,20">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10">
                            <TextBlock Text="Preset:" Foreground="{DynamicResource SubtleTextBrush}" VerticalAlignment="Center"/>
                            <ComboBox ItemsSource="{Binding EqViewModel.EqPresets}"
                                      SelectedItem="{Binding EqViewModel.SelectedEqPreset}"
                                      Width="112"/>
                        </StackPanel>
                    </Grid>

                    <!-- EQ bands -->
                    <Viewbox Grid.Row="1" Stretch="Uniform" StretchDirection="DownOnly">
                        <ItemsControl ItemsSource="{Binding EqViewModel.EqBands}"
                                      HorizontalAlignment="Center">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="25"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Vertical" Spacing="10"
                                                HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding Gain, StringFormat=\{0:F1\}}"
                                                   FontSize="11" Foreground="{DynamicResource EqOverlayTextBrush}"
                                                   HorizontalAlignment="Center"/>
                                        <Slider Minimum="-15" Maximum="15"
                                                Value="{Binding Gain}"
                                                Orientation="Vertical" Height="150"
                                                HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding FrequencyLabel}"
                                                   FontSize="12" Foreground="{DynamicResource SubtleTextBrush}"
                                                   HorizontalAlignment="Center" FontWeight="Bold"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Viewbox>

                </Grid>
            </Border>

        </Grid>
    </Border>

</UserControl>
