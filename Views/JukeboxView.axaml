<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:Jukebox.ViewModels"
        xmlns:views="using:Jukebox.Views"
        mc:Ignorable="d" d:DesignWidth="640" d:DesignHeight="480"
        x:Class="Jukebox.Views.JukeboxView"
        x:DataType="vm:JukeboxViewModel"
        Title="Jukebox"
        Width="640" Height="480"
        MinWidth="640" MinHeight="480"
        CanResize="True"
        WindowStartupLocation="CenterOwner"
        Background="Black"
        Topmost="{Binding StayOnTop}">

    <Design.DataContext>
        <vm:JukeboxViewModel/>
    </Design.DataContext>

    <!-- Host the standalone UI UserControl -->
    <views:JukeboxControl DataContext="{Binding}" />

</Window>
