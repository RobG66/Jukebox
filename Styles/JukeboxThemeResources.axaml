<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Default"> <!-- Light Theme -->
            <SolidColorBrush x:Key="PanelBackground">#F5F5F5</SolidColorBrush>
            <SolidColorBrush x:Key="PanelBorder">#CCCCCC</SolidColorBrush>
            <SolidColorBrush x:Key="SubtleTextBrush">#666666</SolidColorBrush>
            <SolidColorBrush x:Key="AccentTextBrush">#E06400</SolidColorBrush>
            <SolidColorBrush x:Key="ErrorTextBrush">#CC0000</SolidColorBrush>
            <SolidColorBrush x:Key="SliderTrackBrush">#FF7B00</SolidColorBrush>
            <SolidColorBrush x:Key="SliderThumbBrush">#404040</SolidColorBrush>
            <SolidColorBrush x:Key="SliderThumbHoverBrush">#000000</SolidColorBrush>

            <SolidColorBrush x:Key="DataGridColumnHeaderForegroundBrush" Color="#333333"/>
            <SolidColorBrush x:Key="DataGridGridLinesBrush"              Color="#CCCCCC"/>
            <SolidColorBrush x:Key="DataGridColumnHeaderBackgroundBrush" Color="#E5E5E5"/>

            <!-- Theme-Aware Container Brushes -->
            <SolidColorBrush x:Key="WindowBackground">#EAEAEA</SolidColorBrush>
            <SolidColorBrush x:Key="ContentBackground">#FFFFFF</SolidColorBrush>
            <SolidColorBrush x:Key="SplitPaneBackground">#F0F0F0</SolidColorBrush>
            <SolidColorBrush x:Key="PanelTextBrush">#111111</SolidColorBrush>
            <SolidColorBrush x:Key="PickerBorderBackground">#15000000</SolidColorBrush>
            <SolidColorBrush x:Key="EqOverlayBackground">#E6FFFFFF</SolidColorBrush>
            <SolidColorBrush x:Key="EqOverlayTextBrush">#333333</SolidColorBrush>

            <!-- Media drawer -->
            <SolidColorBrush x:Key="MediaDrawerOverlayBackground">#FAF7F7F8</SolidColorBrush>
            <SolidColorBrush x:Key="MediaPanelSurfaceBrush">#FFFFFFFF</SolidColorBrush>
            <SolidColorBrush x:Key="MediaPanelSurfaceAltBrush">#FFF0F1F3</SolidColorBrush>
            <SolidColorBrush x:Key="MediaPanelRailBrush">#FFF3F4F6</SolidColorBrush>
            <SolidColorBrush x:Key="MediaPanelHoverBrush">#14000000</SolidColorBrush>
            <SolidColorBrush x:Key="MediaPanelSelectedBrush">#220078D4</SolidColorBrush>
            <SolidColorBrush x:Key="MediaPanelAccentBrush">#FF7B00</SolidColorBrush>
            <SolidColorBrush x:Key="MediaPanelMutedBrush">#8A000000</SolidColorBrush>
            <SolidColorBrush x:Key="MediaPanelDangerBrush">#CC2B1C</SolidColorBrush>
        </ResourceDictionary>
        <ResourceDictionary x:Key="Dark"> <!-- Dark Theme -->
            <SolidColorBrush x:Key="PanelBackground">#181818</SolidColorBrush>
            <SolidColorBrush x:Key="PanelBorder">#333333</SolidColorBrush>
            <SolidColorBrush x:Key="SubtleTextBrush">#AAAAAA</SolidColorBrush>
            <SolidColorBrush x:Key="AccentTextBrush">#FF7B00</SolidColorBrush>
            <SolidColorBrush x:Key="ErrorTextBrush">#FF4444</SolidColorBrush>
            <SolidColorBrush x:Key="SliderTrackBrush">#FF7B00</SolidColorBrush>
            <SolidColorBrush x:Key="SliderThumbBrush">#E0E0E0</SolidColorBrush>
            <SolidColorBrush x:Key="SliderThumbHoverBrush">#FFFFFF</SolidColorBrush>

            <SolidColorBrush x:Key="DataGridColumnHeaderForegroundBrush" Color="#D0D0D0"/>
            <SolidColorBrush x:Key="DataGridGridLinesBrush"              Color="#404040"/>
            <SolidColorBrush x:Key="DataGridColumnHeaderBackgroundBrush" Color="#333333"/>

            <!-- Theme-Aware Container Brushes -->
            <SolidColorBrush x:Key="WindowBackground">#0D0D0D</SolidColorBrush>
            <SolidColorBrush x:Key="ContentBackground">#222222</SolidColorBrush>
            <SolidColorBrush x:Key="SplitPaneBackground">#1A1A1A</SolidColorBrush>
            <SolidColorBrush x:Key="PanelTextBrush">#FFFFFF</SolidColorBrush>
            <SolidColorBrush x:Key="PickerBorderBackground">#22FFFFFF</SolidColorBrush>
            <SolidColorBrush x:Key="EqOverlayBackground">#B3000000</SolidColorBrush>
            <SolidColorBrush x:Key="EqOverlayTextBrush">#FFFFFF</SolidColorBrush>

            <!-- Media drawer -->
            <SolidColorBrush x:Key="MediaDrawerOverlayBackground">#F2111317</SolidColorBrush>
            <SolidColorBrush x:Key="MediaPanelSurfaceBrush">#FF1B1E23</SolidColorBrush>
            <SolidColorBrush x:Key="MediaPanelSurfaceAltBrush">#FF14171B</SolidColorBrush>
            <SolidColorBrush x:Key="MediaPanelRailBrush">#FF101216</SolidColorBrush>
            <SolidColorBrush x:Key="MediaPanelHoverBrush">#18FFFFFF</SolidColorBrush>
            <SolidColorBrush x:Key="MediaPanelSelectedBrush">#24FF7B00</SolidColorBrush>
            <SolidColorBrush x:Key="MediaPanelAccentBrush">#FF8A1F</SolidColorBrush>
            <SolidColorBrush x:Key="MediaPanelMutedBrush">#A8FFFFFF</SolidColorBrush>
            <SolidColorBrush x:Key="MediaPanelDangerBrush">#FF6868</SolidColorBrush>
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>

    <x:Double x:Key="GlobalSmallFontSize">12</x:Double>
    <x:Double x:Key="GlobalFontSize">14</x:Double>
    <x:Double x:Key="GlobalHeaderFontSize">18</x:Double>
    <x:Double x:Key="DataGridFontSizeResource">12</x:Double>

    <!-- ComboBox Compact Sizing -->
    <x:Double   x:Key="ComboBoxMinHeight">24</x:Double>
    <Thickness  x:Key="ComboBoxPadding">5,2,5,2</Thickness>

</ResourceDictionary>
