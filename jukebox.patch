+    #region Drag / Drop
+
+    private void OnDragOver(object? sender, DragEventArgs e)
+    {
+        // Accept file/folder drops only — no URL/text drops.
+        e.DragEffects = e.Data.Contains(DataFormats.Files)
+            ? DragDropEffects.Copy
+            : DragDropEffects.None;
+        e.Handled = true;
+    }
+
+    private async void OnDrop(object? sender, DragEventArgs e)
+    {
+        e.Handled = true;
+        if (!e.Data.Contains(DataFormats.Files)) return;
+        if (DataContext is not JukeboxViewModel vm) return;
+
+        try
+        {
+            var items = await e.Data.GetFilesAsync();
+            if (items == null) return;
+
+            var paths = new List<string>();
+            foreach (var item in items)
+            {
+                var localPath = item.TryGetLocalPath();
+                if (!string.IsNullOrEmpty(localPath))
+                    paths.Add(localPath);
+            }
+            if (paths.Count == 0) return;
+
+            // Stop current playback before adding the new items. This gives
+            // immediate UI feedback (transport buttons flip to stopped) while
+            // file discovery runs on the background thread. StartTrackAsync
+            // would also cancel any in-flight connection, but the explicit
+            // Stop produces cleaner transport state.
+            if (vm.CanStop)
+                vm.StopCommand.Execute(null);
+
+            // Remember where the dropped items will land so we can play the
+            // first one. ProcessAndAddFilesAsync appends to the end of the
+            // playlist and handles file discovery, folder recursion, zip
+            // extraction, media-extension filtering, and tagging internally.
+            int startIndex = vm.PlaylistViewModel.Playlist.Count;
+
+            await vm.PlaylistViewModel.ProcessAndAddFilesAsync(paths, vm.NoRecurse);
+
+            // Play the first newly-dropped item (if any survived filtering).
+            // PlayTrackCommand is the same command invoked by double-clicking
+            // a row in the playlist.
+            if (startIndex < vm.PlaylistViewModel.Playlist.Count)
+            {
+                var firstDropped = vm.PlaylistViewModel.Playlist[startIndex];
+                if (vm.PlayTrackCommand.CanExecute(firstDropped))
+                    vm.PlayTrackCommand.Execute(firstDropped);
+            }
+        }
+        catch (Exception ex)
+        {
+            Debug.WriteLine($"[JukeboxControl] Drop failed: {ex.Message}");
+        }
+    }
+
+    #endregion
+
